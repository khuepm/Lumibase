{
  "name": "@lumibase/database",
  "version": "0.1.0",
  "private": true,
  "description": "Lumibase Drizzle ORM schema and migrations (PostgreSQL via Cloudflare Hyperdrive).",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema.ts"
  },
  "scripts": {
    "generate": "drizzle-kit generate",
    "migrate": "drizzle-kit migrate",
    "push": "drizzle-kit push",
    "studio": "drizzle-kit studio",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf .turbo drizzle dist"
  },
  "dependencies": {
    "drizzle-orm": "^0.36.4",
    "nanoid": "^5.0.7",
    "postgres": "^3.4.5"
  },
  "devDependencies": {
    "@types/node": "^22.7.4",
    "drizzle-kit": "^0.28.1",
    "typescript": "^5.6.2"
  }
}
