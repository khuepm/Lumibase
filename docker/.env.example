# Lumibase Docker Environment Variables
# Copy this file to .env and adjust values for your environment.

# Runtime mode (docker or cloudflare)
LUMIBASE_RUNTIME=docker

# PostgreSQL connection
DATABASE_URL=postgresql://lumibase:lumibase_dev@postgres:5432/lumibase

# Redis connection
REDIS_URL=redis://redis:6379

# S3-compatible storage (MinIO for local dev)
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=lumibase-media

# MeiliSearch
MEILISEARCH_HOST=http://meilisearch:7700
MEILISEARCH_API_KEY=lumibase_dev_key

# Imgproxy
IMGPROXY_URL=http://imgproxy:8080
IMGPROXY_KEY=736563726574
IMGPROXY_SALT=736563726574

# CMS server port
PORT=3000

# Authentication (OIDC via Logto)
LOGTO_ISSUER=
LOGTO_AUDIENCE=

# Encryption key for sensitive data (base64-encoded AES-GCM key)
ENCRYPTION_KEY=
