# Development image with hot-reload via volume mounting
FROM node:20-slim

# Install pnpm
RUN corepack enable && corepack prepare pnpm@9.12.0 --activate

WORKDIR /app

# Copy workspace configuration and package manifests for dependency installation
COPY pnpm-lock.yaml pnpm-workspace.yaml package.json ./
COPY packages/runtime/package.json ./packages/runtime/
COPY packages/database/package.json ./packages/database/
COPY packages/shared/package.json ./packages/shared/
COPY packages/sdk/package.json ./packages/sdk/
COPY apps/cms/package.json ./apps/cms/

# Install all dependencies (including devDependencies for tsx, typescript, etc.)
RUN pnpm install --frozen-lockfile

# Source code is NOT copied — it will be mounted as a volume at runtime:
#   volumes:
#     - ./apps/cms/src:/app/apps/cms/src
#     - ./packages:/app/packages

# Default environment
ENV LUMIBASE_RUNTIME=docker
ENV NODE_ENV=development
ENV PORT=3000

EXPOSE 3000

# Use tsx watch for hot-reload of TypeScript source files
CMD ["pnpm", "--filter", "@lumibase/cms", "exec", "tsx", "watch", "src/serve.ts"]
