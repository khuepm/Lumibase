{
  "name": "lumibase",
  "version": "0.1.0",
  "private": true,
  "description": "Lumibase - Edge-native Headless CMS (Turborepo monorepo)",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rm -rf node_modules",
    "db:generate": "pnpm --filter @lumibase/database generate",
    "db:migrate": "pnpm --filter @lumibase/database migrate",
    "db:studio": "pnpm --filter @lumibase/database studio"
  },
  "devDependencies": {
    "turbo": "^2.1.3",
    "typescript": "^5.6.2"
  }
}
