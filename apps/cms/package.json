{
  "name": "@lumibase/cms",
  "version": "0.1.0",
  "private": true,
  "description": "Lumibase CMS API — Hono.js on Cloudflare Workers.",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "dev": "wrangler dev",
