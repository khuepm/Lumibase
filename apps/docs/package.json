{
  "name": "@lumibase/docs",
  "version": "0.1.0",
  "private": true,
  "description": "LumiBase Docs Viewer — browse project documentation (React + Vite).",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "echo \"(lint not configured)\" && exit 0",
    "test": "vitest --run",
    "clean": "rm -rf .turbo dist"
  },
  "dependencies": {
    "@lumibase/ui": "workspace:*",
    "@lumibase/shared": "workspace:*",
    "gray-matter": "^4.0.3",
    "lucide-react": "^0.452.0",
    "minisearch": "^7.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.0.1",
    "react-router-dom": "^7.0.0",
    "rehype-shiki": "^0.0.9",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.0",
    "shiki": "^1.22.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.2",
    "@testing-library/react": "^16.0.1",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.2",
    "autoprefixer": "^10.4.20",
    "fast-check": "^3.22.0",
    "jsdom": "^25.0.1",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.13",
    "typescript": "^5.6.2",
    "vite": "^5.4.8",
    "vitest": "^2.1.2"
  }
}
